---
import { getCollection } from 'astro:content';
import ServiceIcon from './ServiceIcon.astro';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="services" class="relative scroll-mt-24 bg-ink-950">
  <div class="mx-auto max-w-7xl px-5 py-24 sm:px-8 sm:py-32">
    <div class="max-w-3xl">
      <div class="reveal"><span class="eyebrow">What we do</span></div>
      <h2 class="reveal mt-5 font-display text-4xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-5xl md:text-6xl" style="transition-delay:80ms">
        Specialist repairs and alterations on <span class="text-chrome">aluminium joinery</span>.
      </h2>
      <p class="reveal mt-5 max-w-2xl text-base leading-relaxed text-ink-300 sm:text-lg" style="transition-delay:160ms">
        No job too small. From a single sticking window to a full commercial fit-out maintenance round, we handle every stage from assessment to fitting.
      </p>
    </div>

    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s, idx) => {
        const slug = s.id.replace(/\.md$/, '');
        return (
          <a
            href={`/services/${slug}`}
            class="card reveal group relative block overflow-hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-chrome-500"
            style={`transition-delay:${Math.min(idx * 60, 360)}ms`}
            aria-label={`${s.data.title}: ${s.data.summary}`}
          >
            <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100 bg-[radial-gradient(ellipse_80%_40%_at_50%_0%,rgba(200,204,211,0.08),transparent_70%)]"></div>

            <div class="relative flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-b from-white/[0.06] to-white/[0.015] ring-1 ring-inset ring-ink-700">
              <ServiceIcon name={s.data.icon} class="h-5 w-5 text-chrome-500" />
            </div>

            <h3 class="relative mt-5 font-display text-lg font-semibold tracking-tight text-ink-50 group-hover:text-chrome-400 transition-colors">
              {s.data.title}
            </h3>
            <p class="relative mt-2 text-sm leading-relaxed text-ink-300">
              {s.data.summary}
            </p>

            <span class="relative mt-5 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.15em] text-chrome-400 transition-colors group-hover:text-ink-50">
              Read more
              <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14" />
                <path d="M13 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        );
      })}
    </div>

    <div class="reveal mt-14 flex flex-wrap items-center justify-between gap-6 rounded-2xl border border-ink-800 bg-white/[0.02] px-6 py-6 sm:px-8" style="transition-delay:120ms">
      <div>
        <p class="font-display text-lg font-semibold text-ink-50">Not sure what you need?</p>
        <p class="mt-1 text-sm text-ink-400">Send a photo and we'll come back with the fix and a fixed price.</p>
      </div>
      <a href="/contact" class="btn btn-primary">Start a job</a>
    </div>
  </div>
</section>
