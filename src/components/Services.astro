---
const services = [
  {
    title: 'Window & Door Repairs',
    description:
      'Sticking, draughty, jamming or misaligned joinery brought back to spec. Seal replacement, realignment, roller repair.',
    icon: 'repair',
  },
  {
    title: 'Broken Glass Replacement',
    description:
      'Fast turnaround on cracked or smashed panes — single glazed, insulated units, safety glass. Homes and shopfronts.',
    icon: 'glass',
  },
  {
    title: 'Retrofit Double Glazing',
    description:
      'Upgrade existing aluminium frames to double-glazed units. Warmer, quieter, more efficient — without replacing the joinery.',
    icon: 'glazing',
  },
  {
    title: 'Hardware Replacement',
    description:
      'Handles, hinges, rollers, friction stays, stays and catches. Colour-matched and fitted properly the first time.',
    icon: 'handle',
  },
  {
    title: 'Locks & Security',
    description:
      'Door and window locks including multi-points, espags and keyed sash fasteners. Repairs, replacements and rekeys.',
    icon: 'lock',
  },
  {
    title: 'General Joinery Maintenance',
    description:
      'Servicing old or tired joinery — weather seals, adjustments, drainage, catches. Keep it working, avoid full replacement.',
    icon: 'maintenance',
  },
];
---

<section id="services" class="relative scroll-mt-24 bg-ink-950">
  <div class="mx-auto max-w-7xl px-5 py-24 sm:px-8 sm:py-32">
    <!-- Section header -->
    <div class="max-w-3xl">
      <div class="reveal"><span class="eyebrow">What we do</span></div>
      <h2 class="reveal mt-5 font-display text-4xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-5xl md:text-6xl" style="transition-delay:80ms">
        Specialist repairs and alterations on <span class="text-chrome">aluminium joinery</span>.
      </h2>
      <p class="reveal mt-5 max-w-2xl text-base leading-relaxed text-ink-300 sm:text-lg" style="transition-delay:160ms">
        No job too small. From a single sticking window to a full commercial fit-out maintenance round, we handle every stage — assessment, parts, fitting.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s, idx) => (
        <article class="card reveal group relative overflow-hidden" style={`transition-delay:${Math.min(idx * 60, 360)}ms`}>
          <!-- Chrome hover highlight -->
          <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100 bg-[radial-gradient(ellipse_80%_40%_at_50%_0%,rgba(200,204,211,0.08),transparent_70%)]"></div>

          <div class="relative flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-b from-white/[0.06] to-white/[0.015] ring-1 ring-inset ring-ink-700">
            <svg class="h-5 w-5 text-chrome-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              {s.icon === 'repair' && (
                <>
                  <rect x="3" y="3" width="12" height="12" rx="1" />
                  <path d="M15 15l4-4a2.828 2.828 0 114 4l-4 4-4-4z" />
                  <path d="M19 19l2 2" />
                </>
              )}
              {s.icon === 'glass' && (
                <>
                  <rect x="3" y="3" width="18" height="18" rx="1.5" />
                  <path d="M3 10l7 4 -3 7" />
                  <path d="M10 14l11 -8" />
                </>
              )}
              {s.icon === 'glazing' && (
                <>
                  <rect x="3" y="3" width="15" height="15" rx="1" />
                  <rect x="6" y="6" width="15" height="15" rx="1" />
                </>
              )}
              {s.icon === 'handle' && (
                <>
                  <rect x="4" y="3" width="10" height="18" rx="1" />
                  <circle cx="17" cy="12" r="1.5" />
                  <path d="M14 12h1.5" />
                </>
              )}
              {s.icon === 'lock' && (
                <>
                  <rect x="4" y="11" width="16" height="10" rx="2" />
                  <path d="M8 11V7a4 4 0 118 0v4" />
                  <circle cx="12" cy="16" r="1.25" />
                </>
              )}
              {s.icon === 'maintenance' && (
                <>
                  <path d="M14 6l4 4" />
                  <path d="M5 21l9-9" />
                  <path d="M16 4l4 4-3 3-4-4z" />
                </>
              )}
            </svg>
          </div>

          <h3 class="relative mt-5 font-display text-lg font-semibold tracking-tight text-ink-50">
            {s.title}
          </h3>
          <p class="relative mt-2 text-sm leading-relaxed text-ink-300">
            {s.description}
          </p>
        </article>
      ))}
    </div>

    <!-- CTA strip under grid -->
    <div class="reveal mt-14 flex flex-wrap items-center justify-between gap-6 rounded-2xl border border-ink-800 bg-white/[0.02] px-6 py-6 sm:px-8" style="transition-delay:120ms">
      <div>
        <p class="font-display text-lg font-semibold text-ink-50">Not sure what you need?</p>
        <p class="mt-1 text-sm text-ink-400">Send a photo and we'll come back with the fix and a fixed price.</p>
      </div>
      <a href="#contact" class="btn btn-primary">Start a job</a>
    </div>
  </div>
</section>
