---
// Hero — full-viewport metallic cinematic opener.
import HeroWindow from './HeroWindow.astro';
---

<section id="top" class="relative overflow-hidden bg-brushed noise isolate">
  <!-- Decorative background accents -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <!-- Subtle brushed-metal diagonal sheen -->
    <div class="absolute inset-0 opacity-[0.06] bg-[linear-gradient(135deg,transparent_0%,transparent_40%,rgba(255,255,255,0.4)_50%,transparent_60%,transparent_100%)]"></div>
    <!-- Vertical fade at bottom into next section -->
    <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-ink-950"></div>
  </div>

  <div class="mx-auto grid min-h-[92vh] max-w-7xl items-center gap-12 px-5 pt-32 pb-20 sm:px-8 md:min-h-screen md:pt-36 lg:grid-cols-12 lg:gap-16">
    <!-- Left column: content -->
    <div class="lg:col-span-7">
      <!-- Eyebrow -->
      <div class="reveal">
        <span class="eyebrow">
          Christchurch &amp; Canterbury · Over 13 Years
        </span>
      </div>

      <!-- H1 -->
      <h1 class="reveal mt-6 font-display text-5xl font-semibold leading-[0.95] tracking-tight text-ink-50 sm:text-6xl md:text-7xl lg:text-[5.25rem]" style="transition-delay:80ms">
        Aluminium joinery, <br class="hidden sm:block" />
        <span class="text-chrome">done right.</span>
      </h1>

      <!-- Subcopy -->
      <p class="reveal mt-7 max-w-xl text-lg leading-relaxed text-ink-300 sm:text-xl" style="transition-delay:160ms">
        Windows, doors, locks and glass. Repairs, replacements and retrofit glazing
        across Christchurch and wider Canterbury — residential and commercial.
      </p>

      <!-- CTAs -->
      <div class="reveal mt-10 flex flex-wrap items-center gap-3" style="transition-delay:240ms">
        <a href="#contact" class="btn btn-primary">
          Get a free quote
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="M13 5l7 7-7 7" />
          </svg>
        </a>
        <a href="tel:+64278456163" class="btn btn-secondary">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          027 845 6163
        </a>
      </div>

      <!-- Stat strip -->
      <div class="reveal mt-16 grid max-w-xl grid-cols-3 gap-6 border-t border-ink-800 pt-8 sm:mt-20" style="transition-delay:340ms">
        <div>
          <div class="font-display text-3xl font-semibold text-ink-50 sm:text-4xl">13+</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-ink-400">Years experience</div>
        </div>
        <div>
          <div class="font-display text-3xl font-semibold text-ink-50 sm:text-4xl">6</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-ink-400">Specialist services</div>
        </div>
        <div>
          <div class="font-display text-3xl font-semibold text-ink-50 sm:text-4xl">Free</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-ink-400">On-site quotes</div>
        </div>
      </div>
    </div>

    <!-- Right column: animated window -->
    <div class="reveal hidden lg:col-span-5 lg:block" style="transition-delay:120ms">
      <HeroWindow />
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#services"
    aria-label="Scroll to services"
    class="absolute bottom-6 left-1/2 hidden -translate-x-1/2 items-center gap-2 text-xs font-medium uppercase tracking-[0.2em] text-ink-500 transition-colors hover:text-ink-300 md:inline-flex"
  >
    Scroll
    <span class="relative block h-8 w-px bg-ink-700 overflow-hidden">
      <span class="absolute inset-x-0 top-0 h-3 animate-[scroll-cue_2.2s_ease-in-out_infinite] bg-chrome-500"></span>
    </span>
  </a>
</section>

<style>
  @keyframes scroll-cue {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(400%); }
  }
</style>
