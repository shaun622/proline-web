---
import Logo from './Logo.astro';

const links = [
  { label: 'Services', href: '#services' },
  { label: 'Why us', href: '#why' },
  { label: 'Our work', href: '#work' },
  { label: 'Contact', href: '#contact' },
];
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 transition-[background-color,border-color,backdrop-filter] duration-500 ease-[var(--ease-out-expo)] border-b border-transparent"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
    <a href="#top" class="shrink-0 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-chrome-500">
      <Logo class="h-9 w-auto text-ink-50" />
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class="rounded-full px-4 py-2 text-sm font-medium text-ink-300 transition-colors duration-200 hover:text-ink-50 hover:bg-white/5"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex shrink-0 items-center gap-2">
      <a
        href="tel:+64278456163"
        class="hidden rounded-full border border-ink-700 bg-white/5 px-4 py-2 text-sm font-semibold text-ink-100 backdrop-blur-sm transition-all hover:border-ink-600 hover:bg-white/10 sm:inline-flex"
      >
        027 845 6163
      </a>
      <a href="#contact" class="btn btn-primary hidden sm:inline-flex text-sm px-5 py-2.5 min-h-0">
        Free quote
      </a>

      <!-- Mobile menu button -->
      <button
        id="nav-toggle"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden min-h-tap min-w-tap inline-flex items-center justify-center rounded-full border border-ink-700 bg-white/5 text-ink-100 backdrop-blur-sm"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden absolute inset-x-0 top-full border-t border-ink-800 bg-ink-950/95 backdrop-blur-xl"
  >
    <nav class="px-5 py-6 flex flex-col gap-1" aria-label="Mobile primary">
      {links.map((l) => (
        <a
          href={l.href}
          class="nav-mobile-link rounded-xl px-4 py-3 text-base font-medium text-ink-200 hover:bg-white/5"
        >
          {l.label}
        </a>
      ))}
      <div class="mt-3 grid grid-cols-2 gap-2">
        <a
          href="tel:+64278456163"
          class="btn btn-secondary text-sm"
        >
          027 845 6163
        </a>
        <a
          href="#contact"
          class="nav-mobile-link btn btn-primary text-sm"
        >
          Free quote
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  // Scroll state — add glass styling once user scrolls past hero threshold.
  function onScroll() {
    if (!nav) return;
    const scrolled = window.scrollY > 24;
    nav.classList.toggle('bg-ink-950/70', scrolled);
    nav.classList.toggle('backdrop-blur-xl', scrolled);
    nav.classList.toggle('border-ink-800/80', scrolled);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });

  // Close mobile menu after clicking a link
  document.querySelectorAll('.nav-mobile-link').forEach((el) => {
    el.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
