---
interface Props {
  name: 'repair' | 'glass' | 'glazing' | 'handle' | 'lock' | 'maintenance';
  class?: string;
}

const { name, class: className = 'h-5 w-5' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {name === 'repair' && (
    <>
      <rect x="3" y="3" width="12" height="12" rx="1" />
      <path d="M15 15l4-4a2.828 2.828 0 114 4l-4 4-4-4z" />
      <path d="M19 19l2 2" />
    </>
  )}
  {name === 'glass' && (
    <>
      <rect x="3" y="3" width="18" height="18" rx="1.5" />
      <path d="M3 10l7 4 -3 7" />
      <path d="M10 14l11 -8" />
    </>
  )}
  {name === 'glazing' && (
    <>
      <rect x="3" y="3" width="15" height="15" rx="1" />
      <rect x="6" y="6" width="15" height="15" rx="1" />
    </>
  )}
  {name === 'handle' && (
    <>
      <rect x="4" y="3" width="10" height="18" rx="1" />
      <circle cx="17" cy="12" r="1.5" />
      <path d="M14 12h1.5" />
    </>
  )}
  {name === 'lock' && (
    <>
      <rect x="4" y="11" width="16" height="10" rx="2" />
      <path d="M8 11V7a4 4 0 118 0v4" />
      <circle cx="12" cy="16" r="1.25" />
    </>
  )}
  {name === 'maintenance' && (
    <>
      <path d="M14 6l4 4" />
      <path d="M5 21l9-9" />
      <path d="M16 4l4 4-3 3-4-4z" />
    </>
  )}
</svg>
