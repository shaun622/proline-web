---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ServiceIcon from '../../components/ServiceIcon.astro';
import FAQList from '../../components/FAQList.astro';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry, all: services },
  }));
}

interface Props {
  entry: CollectionEntry<'services'>;
  all: CollectionEntry<'services'>[];
}

const { entry, all } = Astro.props;
const data = entry.data;
const slug = entry.id.replace(/\.md$/, '');

const relatedSet = new Set(data.related);
const related = all
  .filter((e) => relatedSet.has(e.id.replace(/\.md$/, '')))
  .sort((a, b) => a.data.order - b.data.order);

const site = Astro.site ?? new URL('https://prolinechch.co.nz');
const canonical = new URL(`/services/${slug}`, site).toString();

// Service-specific JSON-LD. Lives alongside the LocalBusiness schema in
// Layout, both are valid on the same page.
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: data.title,
  serviceType: data.title,
  description: data.metaDescription,
  url: canonical,
  areaServed: [
    { '@type': 'City', name: 'Christchurch' },
    { '@type': 'AdministrativeArea', name: 'Canterbury' },
  ],
  provider: {
    '@type': 'LocalBusiness',
    '@id': `${site.toString()}#business`,
    name: 'ProLine Aluminium',
    telephone: '+64278456163',
    email: 'michael@prolinechch.co.nz',
    url: site.toString(),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Services',
      item: new URL('/#services', site).toString(),
    },
    { '@type': 'ListItem', position: 3, name: data.title, item: canonical },
  ],
};
---

<Layout
  title={data.metaTitle}
  description={data.metaDescription}
  canonical={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Nav />

  <main>
    <!-- Service hero -->
    <section class="relative overflow-hidden bg-brushed noise isolate">
      <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-ink-950"></div>

      <div class="mx-auto max-w-5xl px-5 pt-32 pb-20 sm:px-8 sm:pt-36 sm:pb-24">
        <!-- Breadcrumb (visible) -->
        <nav class="text-xs text-ink-500" aria-label="Breadcrumb">
          <ol class="flex flex-wrap items-center gap-1.5">
            <li><a href="/" class="hover:text-ink-200 transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/#services" class="hover:text-ink-200 transition-colors">Services</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-ink-300" aria-current="page">{data.title}</li>
          </ol>
        </nav>

        <div class="mt-10 flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-b from-white/[0.06] to-white/[0.015] ring-1 ring-inset ring-ink-700">
            <ServiceIcon name={data.icon} class="h-6 w-6 text-chrome-500" />
          </div>
          <span class="eyebrow !before:hidden text-chrome-400">Service · Christchurch &amp; Canterbury</span>
        </div>

        <h1 class="reveal mt-6 font-display text-4xl font-semibold leading-[1.05] tracking-tight text-ink-50 sm:text-5xl md:text-6xl">
          {data.h1}
        </h1>

        <p class="reveal mt-6 max-w-3xl text-lg leading-relaxed text-ink-300 sm:text-xl" style="transition-delay:80ms">
          {data.lead}
        </p>

        <div class="reveal mt-10 flex flex-wrap items-center gap-3" style="transition-delay:160ms">
          <a href="/contact" class="btn btn-primary">
            Get a free quote
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" />
              <path d="M13 5l7 7-7 7" />
            </svg>
          </a>
          <a href="tel:+64278456163" class="btn btn-secondary">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            027 845 6163
          </a>
        </div>
      </div>
    </section>

    <!-- What we fix + Signs side-by-side -->
    <section class="relative bg-ink-950">
      <div class="mx-auto max-w-5xl px-5 py-20 sm:px-8 sm:py-24">
        <div class="grid gap-10 lg:grid-cols-2 lg:gap-14">
          <div class="reveal">
            <span class="eyebrow">{data.fixesHeading}</span>
            <ul class="mt-6 space-y-3 text-base text-ink-200 sm:text-lg">
              {data.fixes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-chrome-500"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="reveal" style="transition-delay:120ms">
            <span class="eyebrow">{data.signsHeading}</span>
            <ul class="mt-6 space-y-3 text-base text-ink-200 sm:text-lg">
              {data.signs.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-chrome-500"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="relative border-t border-ink-900 bg-ink-900">
      <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 h-48 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(200,204,211,0.05),transparent_75%)]"></div>
      <div class="relative mx-auto max-w-5xl px-5 py-20 sm:px-8 sm:py-24">
        <div class="reveal"><span class="eyebrow">{data.processHeading}</span></div>
        <h2 class="reveal mt-5 font-display text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl" style="transition-delay:80ms">
          From the first photo to a tidy job site.
        </h2>

        <ol class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {data.process.map((p, idx) => (
            <li class="reveal card relative" style={`transition-delay:${idx * 60}ms`}>
              <span class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-chrome-400">
                Step {idx + 1}
              </span>
              <h3 class="mt-3 font-display text-base font-semibold text-ink-50">
                {p.step}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-300">
                {p.detail}
              </p>
            </li>
          ))}
        </ol>

        {data.pricing && (
          <div class="reveal mt-12 rounded-2xl border border-ink-800 bg-white/[0.02] px-6 py-6 sm:px-8" style="transition-delay:120ms">
            <div class="flex flex-wrap items-center justify-between gap-6">
              <p class="max-w-2xl text-sm leading-relaxed text-ink-300 sm:text-base">
                {data.pricing}
              </p>
              <a href="/contact" class="btn btn-primary text-sm">
                Request a quote
              </a>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- FAQ -->
    {data.faqs.length > 0 && (
      <FAQList
        faqs={data.faqs}
        heading={`${data.title} questions`}
        eyebrow="FAQ"
        intro={`Common questions we get about ${data.title.toLowerCase()} across Christchurch and Canterbury.`}
      />
    )}

    <!-- Related services -->
    {related.length > 0 && (
      <section class="relative border-t border-ink-900 bg-ink-950">
        <div class="mx-auto max-w-5xl px-5 py-20 sm:px-8 sm:py-24">
          <div class="reveal"><span class="eyebrow">Related services</span></div>
          <h2 class="reveal mt-5 font-display text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl" style="transition-delay:80ms">
            Often booked together.
          </h2>

          <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((r) => {
              const rSlug = r.id.replace(/\.md$/, '');
              return (
                <a href={`/services/${rSlug}`} class="card group block">
                  <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-b from-white/[0.06] to-white/[0.015] ring-1 ring-inset ring-ink-700">
                    <ServiceIcon name={r.data.icon} class="h-5 w-5 text-chrome-500" />
                  </div>
                  <h3 class="mt-5 font-display text-lg font-semibold text-ink-50 group-hover:text-chrome-400 transition-colors">
                    {r.data.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-ink-300">
                    {r.data.summary}
                  </p>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <section class="relative border-t border-ink-900 bg-brushed-soft">
      <div class="mx-auto max-w-4xl px-5 py-20 text-center sm:px-8 sm:py-24">
        <h2 class="font-display text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl">
          Want it sorted?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-ink-300 sm:text-lg">
          Send a photo or give Michael a call. Quotes are free, on-site, and no-obligation. Christchurch and Canterbury wide.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="btn btn-primary">Get a free quote</a>
          <a href="tel:+64278456163" class="btn btn-secondary">027 845 6163</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
