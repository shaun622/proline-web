---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

import bikingSelfie from '../assets/family/biking-selfie.jpg';
import connectFour from '../assets/family/connect-four.jpg';
import picnicTable from '../assets/family/picnic-table.jpg';
import familyPortrait from '../assets/family/family-portrait.jpg';
import mabel from '../assets/family/mabel.jpg';
import workTruck from '../assets/work/20260416_145056.jpg';

const site = Astro.site ?? new URL('https://prolinechch.co.nz');
const canonical = new URL('/about', site).toString();

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About ProLine Aluminium',
  url: canonical,
  description:
    'ProLine Aluminium is run by Michael, an aluminium joinery specialist with over 13 years on the tools across Christchurch and Canterbury.',
  mainEntity: {
    '@type': 'Person',
    name: 'Michael',
    jobTitle: 'Owner and Aluminium Specialist',
    worksFor: {
      '@type': 'LocalBusiness',
      '@id': `${site.toString()}#business`,
      name: 'ProLine Aluminium',
    },
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
    { '@type': 'ListItem', position: 2, name: 'About', item: canonical },
  ],
};
---

<Layout
  title="About Michael & ProLine Aluminium | Christchurch Aluminium Specialist"
  description="Meet Michael, the aluminium joinery specialist behind ProLine Aluminium. Owner-operated for over 13 years across Christchurch and Canterbury. Family-run, no subcontractors, no hand-offs."
  canonical={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  </Fragment>

  <Nav />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-brushed noise isolate">
      <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-ink-950"></div>

      <div class="mx-auto max-w-6xl px-5 pt-32 pb-20 sm:px-8 sm:pt-36 sm:pb-24">
        <nav class="text-xs text-ink-500" aria-label="Breadcrumb">
          <ol class="flex flex-wrap items-center gap-1.5">
            <li><a href="/" class="hover:text-ink-200 transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-ink-300" aria-current="page">About</li>
          </ol>
        </nav>

        <div class="mt-10 grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-7">
            <div class="reveal"><span class="eyebrow">About</span></div>
            <h1 class="reveal mt-5 font-display text-5xl font-semibold leading-[1.05] tracking-tight text-ink-50 sm:text-6xl md:text-7xl" style="transition-delay:80ms">
              Aluminium joinery <br />
              is a <span class="text-chrome">craft</span>.
            </h1>
            <p class="reveal mt-7 max-w-2xl text-lg leading-relaxed text-ink-300 sm:text-xl" style="transition-delay:160ms">
              Done well, it lasts a generation. Done badly, it leaks, sticks, and falls apart inside five years. ProLine is built on doing it well, every time.
            </p>
            <div class="reveal mt-10 flex flex-wrap items-center gap-3" style="transition-delay:240ms">
              <a href="/contact" class="btn btn-primary">Talk to Michael</a>
              <a href="tel:+64278456163" class="btn btn-secondary">027 845 6163</a>
            </div>
          </div>

          <div class="reveal lg:col-span-5" style="transition-delay:120ms">
            <figure class="relative overflow-hidden rounded-2xl border border-ink-800">
              <Image
                src={workTruck}
                alt="ProLine Aluminium work vehicle in rural Canterbury with the Southern Alps in the background"
                widths={[400, 720, 1100]}
                sizes="(min-width: 1024px) 40vw, 90vw"
                class="h-full w-full object-cover"
                loading="eager"
              />
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- Story -->
    <section class="relative bg-ink-950">
      <div class="mx-auto max-w-3xl px-5 py-20 sm:px-8 sm:py-28">
        <div class="reveal"><span class="eyebrow">The story</span></div>
        <h2 class="reveal mt-5 font-display text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl" style="transition-delay:80ms">
          Built around family. One tradie. Every job.
        </h2>
        <div class="reveal mt-8 space-y-5 text-base leading-relaxed text-ink-300 sm:text-lg" style="transition-delay:160ms">
          <p>
            Michael started ProLine Aluminium because he wanted to do work he could put his name to. After more than 13 years on the tools across Christchurch and Canterbury, that's still the whole point.
          </p>
          <p>
            ProLine is a one-tradie operation. Michael does the quoting, the fitting, the follow-up. No subcontractors, no hand-offs to crews you've never met. The person you meet is the person doing the work.
          </p>
          <p>
            That keeps things simple. You always know who's accountable. Quotes are honest, jobs are tidy, and standards are the ones Michael wants on his own family's place. Whether it's a single sticking window in a Riccarton villa or a full maintenance round on a Hornby commercial site, every job gets the same care.
          </p>
        </div>
      </div>
    </section>

    <!-- Photo mosaic -->
    <section class="relative border-t border-ink-900 bg-ink-950">
      <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-24">
        <div class="reveal max-w-2xl">
          <span class="eyebrow">Family</span>
          <h2 class="mt-5 font-display text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl">
            The reason the standard never slips.
          </h2>
        </div>

        <div class="reveal mt-12" style="transition-delay:120ms">
          <div class="about-mosaic">
            <figure class="about-photo about-photo--anchor">
              <Image
                src={bikingSelfie}
                alt="Michael on the bike trails with his daughter, both wearing helmets"
                widths={[400, 720, 1100]}
                sizes="(min-width: 1024px) 35vw, (min-width: 640px) 50vw, 100vw"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </figure>
            <figure class="about-photo">
              <Image
                src={connectFour}
                alt="Michael playing giant Connect 4 with his daughter at a Canterbury family park"
                widths={[260, 420, 600]}
                sizes="(min-width: 1024px) 18vw, (min-width: 640px) 25vw, 50vw"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </figure>
            <figure class="about-photo">
              <Image
                src={picnicTable}
                alt="Michael with his daughter at a Canterbury playground picnic table"
                widths={[260, 420, 600]}
                sizes="(min-width: 1024px) 18vw, (min-width: 640px) 25vw, 50vw"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </figure>
            <figure class="about-photo about-photo--mabel">
              <Image
                src={mabel}
                alt="Mabel on a balance bike with the family dog in the backyard"
                widths={[300, 500, 720]}
                sizes="(min-width: 1024px) 18vw, (min-width: 640px) 25vw, 50vw"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </figure>
            <figure class="about-photo about-photo--wide">
              <Image
                src={familyPortrait}
                alt="Michael with his partner and daughter, the family behind ProLine Aluminium"
                widths={[400, 720, 1100]}
                sizes="(min-width: 1024px) 55vw, 100vw"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- Principles -->
    <section class="relative border-t border-ink-900 bg-ink-900">
      <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 h-48 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(200,204,211,0.05),transparent_75%)]"></div>
      <div class="relative mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-24">
        <div class="reveal max-w-2xl">
          <span class="eyebrow">How we work</span>
          <h2 class="mt-5 font-display text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl">
            Four things that don't change.
          </h2>
        </div>

        <ul class="mt-12 grid gap-3 sm:grid-cols-2">
          {[
            {
              eyebrow: 'One person',
              title: 'You always deal with Michael.',
              body: 'No call centres, no project managers, no subcontracted crews. From first phone call to final clean-up, the same hands.',
            },
            {
              eyebrow: 'Honest quotes',
              title: 'Free, on-site, written down.',
              body: 'We come and look properly before pricing. You get a fixed quote, not a vague range. No surprises mid-job.',
            },
            {
              eyebrow: 'Repair first',
              title: 'Replace only when it has to be.',
              body: 'Most aluminium joinery problems are repairable for a fraction of replacement cost. We tell you the truth about what the job actually needs.',
            },
            {
              eyebrow: 'Local, always',
              title: 'Christchurch and Canterbury only.',
              body: 'We turn down work outside the region so we can stay reliable inside it. Quick to respond, easy to call back.',
            },
          ].map((p, idx) => (
            <li class="reveal card" style={`transition-delay:${idx * 70}ms`}>
              <div class="text-[11px] font-semibold uppercase tracking-[0.15em] text-chrome-400">
                {p.eyebrow}
              </div>
              <h3 class="mt-2 font-display text-lg font-semibold text-ink-50">
                {p.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-300">{p.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="relative border-t border-ink-900 bg-brushed-soft">
      <div class="mx-auto max-w-4xl px-5 py-20 text-center sm:px-8 sm:py-24">
        <h2 class="font-display text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl">
          Got a job in mind?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-ink-300 sm:text-lg">
          Send a photo, give us a call, or fill in the form. Quotes are free, on-site, and no-obligation.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="btn btn-primary">Get a free quote</a>
          <a href="tel:+64278456163" class="btn btn-secondary">027 845 6163</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .about-mosaic {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    grid-template-rows: 1fr 1fr auto;
    gap: 0.75rem;
    aspect-ratio: 1 / 1;
  }
  .about-photo {
    position: relative;
    overflow: hidden;
    border-radius: 0.875rem;
    border: 1px solid var(--color-ink-800);
    background: var(--color-ink-900);
    transition: transform 0.45s var(--ease-out-expo), border-color 0.45s var(--ease-out-expo);
  }
  .about-photo:hover {
    transform: translateY(-3px);
    border-color: var(--color-ink-700);
  }
  .about-photo img {
    transition: transform 1.2s var(--ease-out-expo), filter 0.6s var(--ease-out-expo);
    filter: saturate(0.92) brightness(0.96);
  }
  .about-photo:hover img {
    transform: scale(1.04);
    filter: saturate(1) brightness(1);
  }
  .about-photo--anchor {
    grid-column: 1;
    grid-row: 1 / 3;
  }
  .about-photo--anchor img {
    object-position: 50% 82%;
  }
  .about-photo--mabel {
    grid-column: 3;
    grid-row: 1 / 3;
  }
  .about-photo--mabel img {
    object-position: 40% 50%;
  }
  .about-photo--wide {
    grid-column: 1 / -1;
    grid-row: 3;
    aspect-ratio: 16 / 9;
  }
  @media (max-width: 640px) {
    .about-mosaic {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      aspect-ratio: auto;
      gap: 0.625rem;
    }
    .about-photo--anchor,
    .about-photo--mabel,
    .about-photo--wide,
    .about-photo {
      grid-column: 1;
      grid-row: auto;
      aspect-ratio: 4 / 5;
    }
    .about-photo--wide { aspect-ratio: 16 / 10; }
  }
  @media (prefers-reduced-motion: reduce) {
    .about-photo, .about-photo img {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
